@model NexusGear.Models.Testimonial
@{
    ViewData["Title"] = "Add Testimonial";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a href="/Admin/Testimonials" class="btn-nexus-outline btn-nexus-sm"><i class="fas fa-arrow-left me-1"></i>Back</a>
</div>

<div class="glass-card p-4" style="max-width:640px;">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label class="nexus-label">Author Name <span style="color:#ef4444;">*</span></label>
            <input type="text" name="AuthorName" class="nexus-form-control" required placeholder="e.g. John Smith" />
        </div>

        <div class="mb-3">
            <label class="nexus-label">Title / Role <span style="color:var(--text-muted);font-weight:400;">(optional)</span></label>
            <input type="text" name="AuthorTitle" class="nexus-form-control" placeholder="e.g. Pro Gamer, Verified Buyer" />
        </div>

        <div class="mb-3">
            <label class="nexus-label">Rating <span style="color:#ef4444;">*</span></label>
            <select name="Rating" class="nexus-form-control" required>
                <option value="5">⭐⭐⭐⭐⭐ 5 Stars</option>
                <option value="4">⭐⭐⭐⭐ 4 Stars</option>
                <option value="3">⭐⭐⭐ 3 Stars</option>
                <option value="2">⭐⭐ 2 Stars</option>
                <option value="1">⭐ 1 Star</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="nexus-label">Content <span style="color:#ef4444;">*</span></label>
            <textarea name="Content" class="nexus-form-control" rows="4" required placeholder="Write the testimonial text here..."></textarea>
        </div>

        <div class="mb-4">
            <label class="d-flex align-items-center gap-2" style="cursor:pointer;">
                <input type="checkbox" name="IsActive" value="true" checked />
                <span style="color:var(--text-secondary);font-size:0.88rem;">Publish immediately (active)</span>
            </label>
        </div>

        <button type="submit" class="btn-nexus btn-nexus-sm"><i class="fas fa-save me-1"></i>Create Testimonial</button>
    </form>
</div>
