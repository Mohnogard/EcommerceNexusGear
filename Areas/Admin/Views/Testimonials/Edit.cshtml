@model NexusGear.Models.Testimonial
@{
    ViewData["Title"] = "Edit Testimonial";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a href="/Admin/Testimonials" class="btn-nexus-outline btn-nexus-sm"><i class="fas fa-arrow-left me-1"></i>Back</a>
</div>

<div class="glass-card p-4" style="max-width:640px;">
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model.Id" />

        <div class="mb-3">
            <label class="nexus-label">Author Name <span style="color:#ef4444;">*</span></label>
            <input type="text" name="AuthorName" class="nexus-form-control" required value="@Model.AuthorName" />
        </div>

        <div class="mb-3">
            <label class="nexus-label">Title / Role <span style="color:var(--text-muted);font-weight:400;">(optional)</span></label>
            <input type="text" name="AuthorTitle" class="nexus-form-control" value="@Model.AuthorTitle" />
        </div>

        <div class="mb-3">
            <label class="nexus-label">Rating <span style="color:#ef4444;">*</span></label>
            <select name="Rating" class="nexus-form-control" required>
                @for (int i = 5; i >= 1; i--)
                {
                    if (Model.Rating == i)
                    {
                        <option value="@i" selected="selected">@i Star@(i == 1 ? "" : "s")</option>
                    }
                    else
                    {
                        <option value="@i">@i Star@(i == 1 ? "" : "s")</option>
                    }
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="nexus-label">Content <span style="color:#ef4444;">*</span></label>
            <textarea name="Content" class="nexus-form-control" rows="4" required>@Model.Content</textarea>
        </div>

        <div class="mb-4">
            <label class="d-flex align-items-center gap-2" style="cursor:pointer;">
                <input type="checkbox" name="IsActive" value="true" @(Model.IsActive ? "checked" : "") />
                <span style="color:var(--text-secondary);font-size:0.88rem;">Active (visible on homepage)</span>
            </label>
        </div>

        <button type="submit" class="btn-nexus btn-nexus-sm"><i class="fas fa-save me-1"></i>Save Changes</button>
    </form>
</div>
