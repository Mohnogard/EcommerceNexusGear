@model List<NexusGear.Models.Product>
@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <form class="d-flex gap-2 flex-wrap" method="get">
        <input type="text" name="q" value="@ViewBag.Q" class="nexus-form-control" placeholder="Search products..." style="width:220px;" />
        <select name="categoryId" class="nexus-form-control" style="width:160px;" onchange="this.form.submit()">
            <option value="">All Categories</option>
            @foreach (var cat in (List<NexusGear.Models.Category>)ViewBag.Categories)
            {
                <option value="@cat.Id" selected="@(ViewBag.CategoryId?.ToString() == cat.Id.ToString() ? "selected" : null)">@cat.Name</option>
            }
        </select>
        <button type="submit" class="btn-nexus btn-nexus-sm"><i class="fas fa-search me-1"></i>Search</button>
    </form>
    <a href="/Admin/Products/Create" class="btn-nexus btn-nexus-sm"><i class="fas fa-plus me-1"></i>Add Product</a>
</div>

<div class="glass-card">
    <div class="table-responsive">
        <table class="nexus-table">
            <thead>
                <tr><th>Image</th><th>Name</th><th>Category</th><th>Price</th><th>Discount</th><th>Stock</th><th>Flags</th><th>Actions</th></tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>
                            <img src="@(p.ImageUrl ?? "https://placehold.co/50x50/150020/a855f7?text=?")"
                                 style="width:48px;height:48px;object-fit:cover;border-radius:6px;"
                                 onerror="this.src='https://placehold.co/50x50/150020/a855f7?text=?'" />
                        </td>
                        <td>
                            <strong style="color:var(--text-primary);display:block;font-size:0.88rem;">@p.Name</strong>
                            <small style="color:var(--text-muted);">@p.Brand &middot; @p.Sku</small>
                        </td>
                        <td style="color:var(--text-secondary);font-size:0.85rem;">@p.Category?.Name</td>
                        <td style="font-family:'Orbitron',sans-serif;font-size:0.85rem;color:var(--accent);">$@p.Price.ToString("0.00")</td>
                        <td>
                            @if (p.DiscountPercentage > 0)
                            {
                                <span style="color:var(--secondary);font-weight:700;font-size:0.82rem;">@p.DiscountPercentage%</span>
                            }
                            else { <span style="color:var(--text-muted);font-size:0.82rem;">-</span> }
                        </td>
                        <td>
                            @if (p.Stock <= 0)
                            {
                                <span style="color:var(--danger);font-weight:700;font-size:0.82rem;">Out</span>
                            }
                            else if (p.Stock <= 5)
                            {
                                <span style="color:var(--accent);font-size:0.82rem;">@p.Stock (Low)</span>
                            }
                            else
                            {
                                <span style="color:var(--success);font-size:0.82rem;">@p.Stock</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-1 flex-wrap">
                                @if (p.IsFeatured) { <span style="background:rgba(168,85,247,0.15);color:var(--primary);font-size:0.65rem;border-radius:20px;padding:2px 7px;font-weight:600;">Featured</span> }
                                @if (p.IsNewArrival) { <span style="background:rgba(6,182,212,0.15);color:var(--info);font-size:0.65rem;border-radius:20px;padding:2px 7px;font-weight:600;">New</span> }
                                @if (!p.IsActive) { <span style="background:rgba(239,68,68,0.15);color:var(--danger);font-size:0.65rem;border-radius:20px;padding:2px 7px;font-weight:600;">Inactive</span> }
                            </div>
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <a href="/Admin/Products/Edit/@p.Id" class="btn-nexus-outline btn-nexus-sm"><i class="fas fa-edit"></i></a>
                                <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Remove this product?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@p.Id" />
                                    <button type="submit" class="btn-danger-nx"><i class="fas fa-trash"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
