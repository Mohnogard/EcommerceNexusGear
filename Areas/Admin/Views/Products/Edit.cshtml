@model NexusGear.Models.Product
@{
    ViewData["Title"] = "Edit Product";
}

<div style="max-width:900px;">
    <a href="/Admin/Products" class="btn-nexus-outline btn-nexus-sm mb-4"><i class="fas fa-arrow-left me-1"></i>Back</a>

    <div class="glass-card p-4">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="nexus-alert nexus-alert-danger mb-4">
                    @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors)) { <div>@err.ErrorMessage</div> }
                </div>
            }

            <div class="row g-3">
                <div class="col-md-8">
                    <label class="nexus-label">Product Name *</label>
                    <input asp-for="Name" class="nexus-form-control" />
                    <span asp-validation-for="Name" class="field-validation-error"></span>
                </div>
                <div class="col-md-4">
                    <label class="nexus-label">Brand</label>
                    <input asp-for="Brand" class="nexus-form-control" />
                </div>
                <div class="col-md-4">
                    <label class="nexus-label">Category *</label>
                    <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="nexus-form-control"></select>
                    <span asp-validation-for="CategoryId" class="field-validation-error"></span>
                </div>
                <div class="col-md-4">
                    <label class="nexus-label">Price *</label>
                    <input asp-for="Price" type="number" step="0.01" class="nexus-form-control" />
                </div>
                <div class="col-md-4">
                    <label class="nexus-label">Discount %</label>
                    <input asp-for="DiscountPercentage" type="number" step="0.01" class="nexus-form-control" />
                </div>
                <div class="col-md-4">
                    <label class="nexus-label">Stock</label>
                    <input asp-for="Stock" type="number" class="nexus-form-control" />
                </div>
                <div class="col-md-4">
                    <label class="nexus-label">SKU</label>
                    <input asp-for="Sku" class="nexus-form-control" />
                </div>
                <div class="col-md-4">
                    <label class="nexus-label">Slug</label>
                    <input asp-for="Slug" class="nexus-form-control" />
                </div>
                <div class="col-12">
                    <label class="nexus-label">Description</label>
                    <textarea asp-for="Description" class="nexus-form-control" rows="4"></textarea>
                </div>

                <!-- Current main image -->
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="col-12">
                        <label class="nexus-label">Current Main Image</label>
                        <div>
                            <img src="@Model.ImageUrl" style="height:100px;object-fit:cover;border-radius:8px;border:1px solid var(--border);"
                                 onerror="this.style.display='none'" />
                        </div>
                    </div>
                }

                <div class="col-md-6">
                    <label class="nexus-label">Replace Main Image</label>
                    <input type="file" name="mainImage" class="nexus-form-control" accept="image/*" />
                </div>
                <div class="col-md-6">
                    <label class="nexus-label">Add More Images</label>
                    <input type="file" name="additionalImages" class="nexus-form-control" accept="image/*" multiple />
                </div>

                <!-- Existing additional images -->
                @if (Model.Images.Any())
                {
                    <div class="col-12">
                        <label class="nexus-label">Additional Images</label>
                        <div class="d-flex gap-2 flex-wrap">
                            @foreach (var img in Model.Images)
                            {
                                <div class="position-relative">
                                    <img src="@img.ImageUrl" style="height:70px;width:70px;object-fit:cover;border-radius:6px;border:1px solid var(--border);" />
                                    <button type="button" onclick="deleteImage(@img.Id, this)"
                                            style="position:absolute;top:-6px;right:-6px;background:var(--danger);border:none;color:#fff;border-radius:50%;width:20px;height:20px;font-size:10px;cursor:pointer;display:flex;align-items:center;justify-content:center;">
                                        <i class="fas fa-times"></i>
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                }

                <div class="col-12">
                    <div class="d-flex gap-4 flex-wrap">
                        <div class="form-check">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label class="form-check-label nexus-label" asp-for="IsActive" style="margin-bottom:0;">Active</label>
                        </div>
                        <div class="form-check">
                            <input asp-for="IsFeatured" class="form-check-input" />
                            <label class="form-check-label nexus-label" asp-for="IsFeatured" style="margin-bottom:0;">Featured</label>
                        </div>
                        <div class="form-check">
                            <input asp-for="IsNewArrival" class="form-check-input" />
                            <label class="form-check-label nexus-label" asp-for="IsNewArrival" style="margin-bottom:0;">New Arrival</label>
                        </div>
                    </div>
                </div>
                <div class="col-12 mt-2">
                    <button type="submit" class="btn-nexus"><i class="fas fa-save me-2"></i>Save Changes</button>
                    <a href="/Admin/Products" class="btn-nexus-outline ms-2">Cancel</a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function deleteImage(imageId, btn) {
            if (!confirm('Remove this image?')) return;
            const token = document.querySelector('[name=__RequestVerificationToken]')?.value || '';
            fetch('/Admin/Products/DeleteImage', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': token },
                body: 'imageId=' + imageId
            }).then(r => r.json()).then(d => {
                if (d.success) btn.closest('.position-relative').remove();
            });
        }
    </script>
}
