@using Microsoft.AspNetCore.Identity
@inject UserManager<NexusGear.Models.ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NexusGear Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/nexus.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @{
        var currentUser = await UserManager.GetUserAsync(User);
        var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    }

    <!-- Sidebar -->
    <nav class="admin-sidebar" id="adminSidebar">
        <div class="admin-sidebar-logo">NEXUSGEAR</div>
        <p style="font-size:0.7rem;color:var(--text-muted);padding:0 0.75rem 0.5rem;margin-bottom:0.5rem;border-bottom:1px solid var(--border);">Admin Panel</p>

        <div class="admin-nav-section">Main</div>
        <a href="/Admin/Dashboard" class="admin-nav-link @(controller == "Dashboard" ? "active" : "")">
            <i class="fas fa-chart-bar"></i> Dashboard
        </a>

        <div class="admin-nav-section">Catalog</div>
        <a href="/Admin/Products" class="admin-nav-link @(controller == "Products" ? "active" : "")">
            <i class="fas fa-box"></i> Products
        </a>
        <a href="/Admin/Categories" class="admin-nav-link @(controller == "Categories" ? "active" : "")">
            <i class="fas fa-tags"></i> Categories
        </a>

        <div class="admin-nav-section">Operations</div>
        <a href="/Admin/Orders" class="admin-nav-link @(controller == "Orders" ? "active" : "")">
            <i class="fas fa-shopping-cart"></i> Orders
        </a>
        <a href="/Admin/Reviews?pending=true" class="admin-nav-link @(controller == "Reviews" ? "active" : "")">
            <i class="fas fa-star"></i> Reviews
        </a>
        <a href="/Admin/Testimonials?pending=true" class="admin-nav-link @(controller == "Testimonials" ? "active" : "")">
            <i class="fas fa-comments"></i> Testimonials
        </a>
        <a href="/Admin/Users" class="admin-nav-link @(controller == "Users" ? "active" : "")">
            <i class="fas fa-users"></i> Users
        </a>

        <div class="admin-nav-section">Store</div>
        <a href="/" class="admin-nav-link" target="_blank">
            <i class="fas fa-store"></i> View Store
        </a>
        <form asp-controller="Account" asp-action="Logout" asp-area="" method="post" class="mt-auto">
            @Html.AntiForgeryToken()
            <button type="submit" class="admin-nav-link w-100 text-start" style="background:none;border:none;cursor:pointer;">
                <i class="fas fa-sign-out-alt"></i> Logout
            </button>
        </form>
    </nav>

    <!-- Top Bar -->
    <div class="admin-topbar">
        <div class="d-flex align-items-center gap-3">
            <button class="d-lg-none" id="sidebarToggle" style="background:none;border:none;color:var(--text-secondary);font-size:1.1rem;">
                <i class="fas fa-bars"></i>
            </button>
            <h1 style="font-family:'Orbitron',sans-serif;font-size:0.9rem;font-weight:700;margin:0;color:var(--text-primary);">@ViewData["Title"]</h1>
        </div>
        <div class="d-flex align-items-center gap-3">
            <span style="font-size:0.82rem;color:var(--text-muted);">@currentUser?.FirstName @currentUser?.LastName</span>
        </div>
    </div>

    <!-- Main Content -->
    <main class="admin-main">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/nexus.js"></script>
    <script>
        document.getElementById('sidebarToggle')?.addEventListener('click', () => {
            document.getElementById('adminSidebar')?.classList.toggle('open');
        });
        document.addEventListener('DOMContentLoaded', () => {
            @if (TempData["Success"] != null) {
                <text>showToast('@Html.Raw(Html.Encode(TempData["Success"]!.ToString()))', 'success');</text>
            }
            @if (TempData["Error"] != null) {
                <text>showToast('@Html.Raw(Html.Encode(TempData["Error"]!.ToString()))', 'error');</text>
            }
            document.querySelectorAll('form[data-confirm]').forEach(form => {
                form.addEventListener('submit', function (e) {
                    e.preventDefault();
                    const self = this;
                    Swal.fire({
                        title: this.dataset.confirmTitle || 'Are you sure?',
                        text: this.dataset.confirm,
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonText: this.dataset.confirmBtn || 'Yes, proceed',
                        cancelButtonText: 'Cancel',
                        background: '#150020',
                        color: '#f1e8ff',
                        confirmButtonColor: this.dataset.confirmColor || '#ef4444',
                        cancelButtonColor: '#7c22d4',
                        iconColor: '#f59e0b',
                    }).then(result => {
                        if (result.isConfirmed) HTMLFormElement.prototype.submit.call(self);
                    });
                });
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
