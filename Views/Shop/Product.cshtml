@model NexusGear.ViewModels.ProductDetailViewModel
@using Microsoft.AspNetCore.Identity
@inject SignInManager<NexusGear.Models.ApplicationUser> SignInManager
@{
    var p = Model.Product;
    ViewData["Title"] = p.Name + " - NexusGear";
    string fallback = $"https://placehold.co/600x500/150020/a855f7?text={Uri.EscapeDataString(p.Name)}";
}

<div class="container py-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <li class="breadcrumb-item"><a href="/Shop">Shop</a></li>
            @if (p.Category != null)
            {
                <li class="breadcrumb-item"><a href="/Shop?categoryId=@p.CategoryId">@p.Category.Name</a></li>
            }
            <li class="breadcrumb-item active">@p.Name</li>
        </ol>
    </nav>

    <div class="row g-5">
        <!-- Gallery -->
        <div class="col-lg-5">
            <div class="product-detail-gallery">
                <img id="mainProductImg"
                     src="@(p.ImageUrl ?? fallback)"
                     alt="@p.Name"
                     class="main-img"
                     onerror="this.src='@fallback'" />

                @if (p.Images.Any())
                {
                    <div class="thumbnail-strip">
                        <img class="thumbnail active"
                             src="@(p.ImageUrl ?? fallback)"
                             data-src="@(p.ImageUrl ?? fallback)"
                             alt="Main" />
                        @foreach (var img in p.Images.OrderBy(i => i.DisplayOrder))
                        {
                            <img class="thumbnail"
                                 src="@img.ImageUrl"
                                 data-src="@img.ImageUrl"
                                 alt="Product image" />
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Details -->
        <div class="col-lg-7">
            @if (!string.IsNullOrEmpty(p.Brand))
            {
                <p class="product-brand mb-2">@p.Brand @(!string.IsNullOrEmpty(p.Sku) ? "· SKU: " + p.Sku : "")</p>
            }
            <h1 style="font-family:'Exo 2',sans-serif;font-size:1.7rem;font-weight:800;color:var(--text-primary);margin-bottom:0.75rem;">@p.Name</h1>

            <!-- Rating -->
            <div class="d-flex align-items-center gap-2 mb-3">
                <div class="stars">
                    @for (int i = 1; i <= 5; i++) { <i class="fas fa-star @(i <= Math.Round(p.AverageRating) ? "filled" : "")"></i> }
                </div>
                <span style="color:var(--text-muted);font-size:0.85rem;">@p.AverageRating.ToString("0.0") (@p.ReviewCount review@(p.ReviewCount == 1 ? "" : "s"))</span>
            </div>

            <!-- Price + Discount -->
            <div class="d-flex align-items-center gap-3 mb-4">
                @if (p.DiscountPercentage > 0)
                {
                    <span class="price-current" style="font-size:1.7rem;">$@p.DiscountedPrice.ToString("0.00")</span>
                    <span class="price-original" style="font-size:1.1rem;">$@p.Price.ToString("0.00")</span>
                    <span class="discount-ribbon-detail">-@p.DiscountPercentage.ToString("0")% OFF</span>
                }
                else
                {
                    <span class="price-current" style="font-size:1.7rem;">$@p.Price.ToString("0.00")</span>
                }
            </div>

            <!-- Stock Status -->
            <div class="mb-4">
                @if (p.IsOutOfStock)
                {
                    <span style="background:rgba(239,68,68,0.12);color:#ef4444;border:1px solid rgba(239,68,68,0.3);font-family:'Orbitron',sans-serif;font-size:0.72rem;font-weight:700;letter-spacing:1px;padding:5px 14px;border-radius:20px;">
                        <i class="fas fa-times-circle me-1"></i>OUT OF STOCK
                    </span>
                }
                else if (p.Stock <= 5)
                {
                    <span style="background:rgba(245,158,11,0.12);color:#f59e0b;border:1px solid rgba(245,158,11,0.3);font-family:'Orbitron',sans-serif;font-size:0.72rem;font-weight:700;letter-spacing:1px;padding:5px 14px;border-radius:20px;">
                        <i class="fas fa-exclamation-triangle me-1"></i>ONLY @p.Stock LEFT
                    </span>
                }
                else
                {
                    <span style="background:rgba(16,185,129,0.12);color:#10b981;border:1px solid rgba(16,185,129,0.3);font-family:'Orbitron',sans-serif;font-size:0.72rem;font-weight:700;letter-spacing:1px;padding:5px 14px;border-radius:20px;">
                        <i class="fas fa-check-circle me-1"></i>IN STOCK
                    </span>
                }
            </div>

            <!-- Description -->
            @if (!string.IsNullOrEmpty(p.Description))
            {
                <p style="color:var(--text-secondary);line-height:1.75;font-size:0.92rem;margin-bottom:1.5rem;">@p.Description</p>
            }

            <!-- Add to Cart -->
            <div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
                <div class="d-flex align-items-center gap-2">
                    <label class="nexus-label mb-0" style="white-space:nowrap;">Qty:</label>
                    <input type="text" inputmode="numeric" pattern="[0-9]*" id="detailQty" class="qty-input-detail" value="1" autocomplete="off" />
                </div>
                <button class="btn-nexus btn-nexus-lg flex-1"
                        id="addToCartBtn"
                        onclick="addToCartDetail(@p.Id)"
                        @(p.IsOutOfStock ? "disabled" : "")>
                    <i class="fas fa-cart-plus me-2"></i>@(p.IsOutOfStock ? "Out of Stock" : "Add to Cart")
                </button>
                <button class="btn-wishlist @(Model.IsInWishlist ? "active" : "")"
                        style="width:48px;height:48px;"
                        onclick="toggleWishlist(@p.Id, this)"
                        title="@(Model.IsInWishlist ? "Remove from Wishlist" : "Add to Wishlist")">
                    <i class="@(Model.IsInWishlist ? "fas" : "far") fa-heart"></i>
                </button>
            </div>

            <!-- Meta -->
            <div class="mt-4 pt-3" style="border-top:1px solid var(--border);">
                <div class="d-flex gap-4 flex-wrap" style="font-size:0.83rem;color:var(--text-muted);">
                    @if (p.Category != null) { <span><strong style="color:var(--text-secondary);">Category:</strong> <a href="/Shop?categoryId=@p.CategoryId" style="color:var(--primary-light);">@p.Category.Name</a></span> }
                    @if (!string.IsNullOrEmpty(p.Brand)) { <span><strong style="color:var(--text-secondary);">Brand:</strong> @p.Brand</span> }
                    @if (!string.IsNullOrEmpty(p.Sku)) { <span><strong style="color:var(--text-secondary);">SKU:</strong> @p.Sku</span> }
                </div>
            </div>
        </div>
    </div>

    <!-- Reviews -->
    <div class="row mt-5 pt-4" style="border-top:1px solid var(--border);">
        <div class="col-lg-8">
            <h3 style="font-family:'Orbitron',sans-serif;font-size:1rem;font-weight:700;margin-bottom:1.5rem;color:var(--text-primary);">
                Customer Reviews <span style="color:var(--primary);font-size:0.85rem;">(@p.Reviews.Count(r => r.IsApproved))</span>
            </h3>

            @if (!p.Reviews.Any(r => r.IsApproved))
            {
                <p style="color:var(--text-muted);font-size:0.88rem;">No reviews yet. Be the first to review this product!</p>
            }
            else
            {
                @foreach (var review in p.Reviews.Where(r => r.IsApproved).OrderByDescending(r => r.CreatedAt))
                {
                    <div class="glass-card p-3 mb-3">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <div class="author-avatar" style="width:34px;height:34px;font-size:0.85rem;">@(review.User?.FirstName?.FirstOrDefault() ?? '?')</div>
                            <div>
                                <p style="margin:0;font-weight:700;font-size:0.88rem;color:var(--text-primary);">@review.User?.FullName</p>
                                <p style="margin:0;font-size:0.72rem;color:var(--text-muted);">@review.CreatedAt.ToString("MMM d, yyyy")</p>
                            </div>
                            <div class="stars ms-auto">
                                @for (int i = 1; i <= 5; i++) { <i class="fas fa-star @(i <= review.Rating ? "filled" : "")"></i> }
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(review.Content))
                        {
                            <p style="color:var(--text-secondary);font-size:0.88rem;margin:0;line-height:1.65;">@review.Content</p>
                        }
                    </div>
                }
            }

            <!-- Write a Review -->
            @if (SignInManager.IsSignedIn(User) && !Model.UserHasReviewed)
            {
                <div class="glass-card p-4 mt-4">
                    <h4 style="font-family:'Orbitron',sans-serif;font-size:0.88rem;font-weight:700;margin-bottom:1rem;color:var(--primary-light);">Write a Review</h4>
                    <form action="/Shop/SubmitReview" method="post" id="reviewForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="productId" value="@p.Id" />
                        <div class="mb-3">
                            <label class="nexus-label">Rating <span style="color:#ef4444;">*</span></label>
                            <div class="d-flex gap-2" id="starRating">
                                @for (int s = 1; s <= 5; s++)
                                {
                                    <label style="cursor:pointer;font-size:1.3rem;color:var(--text-muted);">
                                        <input type="radio" name="rating" value="@s" style="display:none;" />
                                        <i class="fas fa-star" style="transition:color 0.15s;"></i>
                                    </label>
                                }
                            </div>
                            <div id="ratingError" style="display:none;color:#ef4444;font-size:0.78rem;margin-top:4px;">Please select a star rating.</div>
                        </div>
                        <div class="mb-3">
                            <label class="nexus-label">Your Review <span style="color:var(--text-muted);">(optional)</span></label>
                            <textarea name="content" class="nexus-form-control" rows="3" placeholder="Share your experience..."></textarea>
                        </div>
                        <button type="submit" class="btn-nexus btn-nexus-sm">Submit Review</button>
                    </form>
                </div>
            }
            else if (!SignInManager.IsSignedIn(User))
            {
                <div class="nexus-alert nexus-alert-info">
                    <a href="/Account/Login?returnUrl=/shop/@p.Slug" style="color:var(--primary-light);">Login</a> to write a review.
                </div>
            }
        </div>
    </div>

    <!-- Related Products -->
    @if (Model.RelatedProducts.Any())
    {
        <div class="mt-5 pt-4" style="border-top:1px solid var(--border);">
            <h3 style="font-family:'Orbitron',sans-serif;font-size:1rem;font-weight:700;margin-bottom:1.5rem;color:var(--text-primary);">Related Products</h3>
            <div class="row g-3">
                @foreach (var rp in Model.RelatedProducts)
                {
                    @await Html.PartialAsync("_ProductCard", rp)
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Star rating hover
        const starLabels = Array.from(document.querySelectorAll('#starRating label'));
        starLabels.forEach((label, idx) => {
            label.addEventListener('mouseover', () => {
                starLabels.forEach((l, i) => l.querySelector('i').style.color = i <= idx ? 'var(--accent)' : 'var(--text-muted)');
            });
            label.addEventListener('mouseout', () => {
                const checked = document.querySelector('input[name="rating"]:checked');
                const ci = checked ? parseInt(checked.value) - 1 : -1;
                starLabels.forEach((l, i) => l.querySelector('i').style.color = i <= ci ? 'var(--accent)' : 'var(--text-muted)');
            });
            label.addEventListener('click', () => {
                label.querySelector('input').checked = true;
                starLabels.forEach((l, i) => l.querySelector('i').style.color = i <= idx ? 'var(--accent)' : 'var(--text-muted)');
                document.getElementById('ratingError')?.style.setProperty('display', 'none');
            });
        });

        // Require rating before submit
        document.getElementById('reviewForm')?.addEventListener('submit', function(e) {
            const checked = document.querySelector('input[name="rating"]:checked');
            if (!checked) {
                e.preventDefault();
                const err = document.getElementById('ratingError');
                if (err) err.style.display = 'block';
            }
        });

        // Qty input validation (free-type, no +/- buttons)
        const qtyInput = document.getElementById('detailQty');
        const maxStock = @p.Stock;
        if (qtyInput) {
            qtyInput.addEventListener('change', () => {
                let v = parseInt(qtyInput.value);
                if (isNaN(v) || v < 1) { qtyInput.value = 1; return; }
                if (v > maxStock) {
                    showToast('Only ' + maxStock + ' in stock', 'warning');
                    qtyInput.value = maxStock;
                }
            });
            qtyInput.addEventListener('keydown', (e) => {
                // Allow: backspace, delete, tab, arrows, digits
                if ([8,9,37,38,39,40,46].includes(e.keyCode)) return;
                if (e.key < '0' || e.key > '9') e.preventDefault();
            });
        }

        function addToCartDetail(productId) {
            const qty = parseInt(document.getElementById('detailQty').value) || 1;
            const btn = document.getElementById('addToCartBtn');
            addToCart(productId, qty, btn);
        }

        // Show review toast via SweetAlert2
        @if (TempData["ReviewMsg"] != null) {
            <text>document.addEventListener('DOMContentLoaded', () => showToast('@Html.Raw(Html.Encode(TempData["ReviewMsg"]!.ToString()))', 'success'));</text>
        }
    </script>
}
