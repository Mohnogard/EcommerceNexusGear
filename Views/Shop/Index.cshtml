@model NexusGear.ViewModels.ShopViewModel
@{
    ViewData["Title"] = "Shop - NexusGear";
}

<div class="container py-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <li class="breadcrumb-item active">Shop</li>
            @if (Model.SelectedCategoryId.HasValue)
            {
                var cat = Model.Categories.FirstOrDefault(c => c.Id == Model.SelectedCategoryId);
                <li class="breadcrumb-item active">@cat?.Name</li>
            }
        </ol>
    </nav>

    <div class="row g-4">
        <!-- Sidebar -->
        <div class="col-lg-3">
            <div class="filter-panel sticky-top" style="top:90px;">
                <p class="filter-heading"><i class="fas fa-sliders-h me-2"></i>Filters</p>
                <form method="get" id="filterForm">

                    <!-- Categories -->
                    <div class="mb-4">
                        <p class="filter-heading" style="font-size:0.7rem;">Category</p>
                        <a href="/Shop@(Model.OnlyDiscounted ? "?onlyDiscounted=true" : "")"
                           class="filter-category-link @(Model.SelectedCategoryId == null ? "active" : "")">
                            All Categories
                            <span class="filter-category-count">@Model.Categories.Sum(c => c.Products.Count)</span>
                        </a>
                        @foreach (var cat in Model.Categories)
                        {
                            <a href="/Shop?categoryId=@cat.Id@(Model.OnlyDiscounted ? "&onlyDiscounted=true" : "")"
                               class="filter-category-link @(Model.SelectedCategoryId == cat.Id ? "active" : "")">
                                @cat.Name
                                <span class="filter-category-count">@cat.Products.Count(p => p.IsActive)</span>
                            </a>
                        }
                    </div>

                    <!-- Price Range -->
                    <div class="mb-4">
                        <p class="filter-heading" style="font-size:0.7rem;">Price Range</p>
                        <div class="row g-2">
                            <div class="col-6">
                                <input type="number" name="minPrice" class="nexus-form-control" placeholder="Min $" value="@Model.MinPrice" style="padding:0.5rem 0.75rem!important;font-size:0.82rem!important;" />
                            </div>
                            <div class="col-6">
                                <input type="number" name="maxPrice" class="nexus-form-control" placeholder="Max $" value="@Model.MaxPrice" style="padding:0.5rem 0.75rem!important;font-size:0.82rem!important;" />
                            </div>
                        </div>
                        @if (Model.SelectedCategoryId.HasValue)
                        {
                            <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
                        }
                    </div>

                    <!-- Discount toggle -->
                    <div class="mb-4">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="onlyDiscounted" value="true" id="discountCheck"
                                   @(Model.OnlyDiscounted ? "checked" : "") onchange="this.form.submit()" />
                            <label class="form-check-label nexus-label" for="discountCheck" style="cursor:pointer;">Discounted Items Only</label>
                        </div>
                    </div>

                    <button type="submit" class="btn-nexus w-100 btn-nexus-sm mb-2">Apply Filters</button>
                    <a href="/Shop" class="btn-nexus-outline w-100 btn-nexus-sm" style="justify-content:center;">Clear All</a>
                </form>
            </div>
        </div>

        <!-- Products Grid -->
        <div class="col-lg-9">
            <!-- Toolbar -->
            <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
                <p class="mb-0" style="color:var(--text-muted);font-size:0.85rem;">
                    Showing <strong style="color:var(--text-primary);">@Model.Products.Count</strong> of <strong style="color:var(--text-primary);">@Model.TotalCount</strong> products
                </p>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <form action="/Shop" method="get" class="d-flex gap-1">
                        <input type="text" name="q" class="nexus-form-control" placeholder="Search..." value="@Model.SearchQuery"
                               style="width:160px;padding:0.42rem 0.85rem!important;font-size:0.82rem!important;border-radius:var(--radius) 0 0 var(--radius)!important;" />
                        @if (Model.SelectedCategoryId.HasValue) { <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" /> }
                        <button class="btn-nexus btn-nexus-sm" style="border-radius:0 var(--radius) var(--radius) 0;"><i class="fas fa-search"></i></button>
                    </form>
                    @{
                        var catP = Model.SelectedCategoryId.HasValue ? "&categoryId=" + Model.SelectedCategoryId : "";
                        var discP = Model.OnlyDiscounted ? "&onlyDiscounted=true" : "";
                    }
                    @{
                        var sortChoices = new (string Value, string Label)[] {
                            ("", "Sort: Name"),
                            ("price_asc", "Price: Low to High"),
                            ("price_desc", "Price: High to Low"),
                            ("newest", "Newest First"),
                            ("discount", "Biggest Discount"),
                            ("rating", "Highest Rated")
                        };
                    }
                    <select class="nexus-form-control" style="width:175px;padding:0.42rem 0.85rem!important;font-size:0.82rem!important;"
                            onchange="window.location.href='/Shop?sortBy='+this.value+'@Html.Raw(catP)@Html.Raw(discP)'">
                        @foreach (var sc in sortChoices)
                        {
                            if (sc.Value == (Model.SortBy ?? ""))
                            {
                                <option value="@sc.Value" selected>@sc.Label</option>
                            }
                            else
                            {
                                <option value="@sc.Value">@sc.Label</option>
                            }
                        }
                    </select>
                </div>
            </div>

            @if (!Model.Products.Any())
            {
                <div class="empty-state">
                    <i class="fas fa-search"></i>
                    <h4>No products found</h4>
                    <p>Try adjusting your filters or search terms</p>
                    <a href="/Shop" class="btn-nexus btn-nexus-sm">Clear Filters</a>
                </div>
            }
            else
            {
                <div class="row g-3">
                    @foreach (var product in Model.Products)
                    {
                        @await Html.PartialAsync("_ProductCard", product)
                    }
                </div>

                @if (Model.TotalPages > 1)
                {
                    <nav class="mt-5 d-flex justify-content-center">
                        <ul class="pagination">
                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.Page ? "active" : "")">
                                    <a class="page-link" href="/Shop?page=@i@(Model.SelectedCategoryId.HasValue ? "&categoryId="+Model.SelectedCategoryId : "")@(Model.SortBy != null ? "&sortBy="+Model.SortBy : "")@(Model.OnlyDiscounted ? "&onlyDiscounted=true" : "")@(!string.IsNullOrEmpty(Model.SearchQuery) ? "&q="+Uri.EscapeDataString(Model.SearchQuery) : "")">@i</a>
                                </li>
                            }
                        </ul>
                    </nav>
                }
            }
        </div>
    </div>
</div>
