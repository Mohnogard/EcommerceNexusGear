@model NexusGear.Models.Order
@{
    ViewData["Title"] = "Order Confirmed - NexusGear";
}

<div class="container py-5" style="max-width:800px;">
    <!-- Success Header -->
    <div class="text-center mb-5">
        <div style="width:80px;height:80px;background:linear-gradient(135deg,var(--primary-dark),var(--secondary-dark));border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;box-shadow:var(--glow-md);">
            <i class="fas fa-check" style="font-size:2rem;color:#fff;"></i>
        </div>
        <h1 style="font-family:'Orbitron',sans-serif;font-size:1.6rem;font-weight:800;color:var(--text-primary);">Order Confirmed!</h1>
        <p style="color:var(--text-muted);font-size:0.95rem;margin-top:0.5rem;">
            Thank you for your order. We'll have it ready to ship soon!
        </p>
        <div style="background:rgba(168,85,247,0.08);border:1px solid var(--border);border-radius:var(--radius);padding:0.75rem 1.5rem;display:inline-block;margin-top:1rem;">
            <span style="color:var(--text-muted);font-size:0.8rem;text-transform:uppercase;letter-spacing:1px;">Order Number</span>
            <p style="font-family:'Orbitron',sans-serif;font-size:1.1rem;font-weight:700;color:var(--primary-light);margin:0;">#@Model.OrderNumber</p>
        </div>
    </div>

    <!-- Order Details Card -->
    <div class="glass-card p-4 mb-4">
        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <p style="font-size:0.72rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-muted);margin-bottom:0.25rem;">Order Date</p>
                <p style="font-weight:600;color:var(--text-primary);margin:0;">@Model.CreatedAt.ToString("MMMM d, yyyy")</p>
            </div>
            <div class="col-md-4">
                <p style="font-size:0.72rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-muted);margin-bottom:0.25rem;">Payment Method</p>
                <p style="font-weight:600;color:var(--text-primary);margin:0;">@(Model.PaymentMethod == "card" ? "Credit / Debit Card" : "Cash on Delivery")</p>
            </div>
            <div class="col-md-4">
                <p style="font-size:0.72px;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-muted);margin-bottom:0.25rem;">Status</p>
                <span class="status-badge status-@Model.Status">@Model.Status</span>
            </div>
        </div>

        <!-- Items -->
        <p style="font-family:'Orbitron',sans-serif;font-size:0.82rem;font-weight:700;color:var(--primary-light);margin-bottom:1rem;border-bottom:1px solid var(--border);padding-bottom:0.5rem;">Order Items</p>
        @foreach (var item in Model.OrderItems)
        {
            <div class="d-flex justify-content-between align-items-center py-2" style="border-bottom:1px solid rgba(168,85,247,0.08);">
                <div>
                    <p style="font-weight:600;color:var(--text-primary);margin:0;font-size:0.9rem;">@(item.ProductName ?? item.Product?.Name)</p>
                    <p style="color:var(--text-muted);font-size:0.78rem;margin:0;">Qty: @item.Quantity × $@item.UnitPrice.ToString("0.00")</p>
                </div>
                <p style="font-family:'Orbitron',sans-serif;font-weight:700;color:var(--accent);margin:0;">$@item.Total.ToString("0.00")</p>
            </div>
        }

        <!-- Totals -->
        <div class="mt-3">
            <div class="d-flex justify-content-between py-1" style="color:var(--text-muted);font-size:0.88rem;">
                <span>Subtotal</span><span>$@Model.Subtotal.ToString("0.00")</span>
            </div>
            <div class="d-flex justify-content-between py-1" style="color:var(--text-muted);font-size:0.88rem;">
                <span>Shipping</span>
                <span style="@(Model.ShippingCost == 0 ? "color:var(--success);" : "")">@(Model.ShippingCost == 0 ? "FREE" : "$" + Model.ShippingCost.ToString("0.00"))</span>
            </div>
            <div class="d-flex justify-content-between py-2 mt-1" style="border-top:1px solid var(--border);">
                <strong style="color:var(--text-primary);">Total</strong>
                <strong style="font-family:'Orbitron',sans-serif;font-size:1.1rem;color:var(--accent);">$@Model.Total.ToString("0.00")</strong>
            </div>
        </div>
    </div>

    <!-- Shipping Address -->
    <div class="glass-card p-4 mb-4">
        <p style="font-family:'Orbitron',sans-serif;font-size:0.82rem;font-weight:700;color:var(--primary-light);margin-bottom:0.75rem;">Shipping Address</p>
        <p style="color:var(--text-secondary);margin:0;line-height:1.7;">
            @Model.User?.FullName<br />
            @Model.ShippingAddress<br />
            @Model.ShippingCity, @Model.ShippingCountry @Model.ShippingPostalCode
        </p>
    </div>

    <!-- Actions -->
    <div class="d-flex gap-3 justify-content-center flex-wrap mt-4">
        <a href="/Dashboard/Orders" class="btn-nexus btn-nexus-sm"><i class="fas fa-box me-2"></i>View My Orders</a>
        <a href="/Shop" class="btn-nexus-outline btn-nexus-sm"><i class="fas fa-store me-2"></i>Continue Shopping</a>
    </div>
</div>
