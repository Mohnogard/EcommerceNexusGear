@model NexusGear.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Register - NexusGear";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="min-height:80vh;display:flex;align-items:center;justify-content:center;padding:3rem 1rem;background:radial-gradient(ellipse at 50% 0%, rgba(236,72,153,0.07) 0%, transparent 60%);">
    <div class="auth-card" style="max-width:480px;">
        <div class="text-center mb-4">
            <a href="/" style="font-family:'Orbitron',sans-serif;font-size:1.3rem;font-weight:900;background:linear-gradient(135deg,var(--primary),var(--secondary));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;text-decoration:none;">NEXUSGEAR</a>
            <h1 class="auth-title mt-3 mb-1">Create Account</h1>
            <p style="color:var(--text-muted);font-size:0.85rem;">Join the NexusGear community</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="nexus-alert nexus-alert-danger mb-3">
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@err.ErrorMessage</div>
                }
            </div>
        }

        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ReturnUrl" />

            <div class="row g-3 mb-3">
                <div class="col-6">
                    <label class="nexus-label">First Name *</label>
                    <input asp-for="FirstName" class="nexus-form-control" placeholder="John" />
                    <span asp-validation-for="FirstName" class="field-validation-error"></span>
                </div>
                <div class="col-6">
                    <label class="nexus-label">Last Name *</label>
                    <input asp-for="LastName" class="nexus-form-control" placeholder="Doe" />
                    <span asp-validation-for="LastName" class="field-validation-error"></span>
                </div>
            </div>
            <div class="mb-3">
                <label class="nexus-label">Email Address *</label>
                <input asp-for="Email" type="email" class="nexus-form-control" placeholder="your@email.com" />
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>
            <div class="mb-3">
                <label class="nexus-label">Password *</label>
                <input asp-for="Password" type="password" class="nexus-form-control" placeholder="Min 6 chars, 1 uppercase, 1 symbol" />
                <span asp-validation-for="Password" class="field-validation-error"></span>
            </div>
            <div class="mb-4">
                <label class="nexus-label">Confirm Password *</label>
                <input asp-for="ConfirmPassword" type="password" class="nexus-form-control" placeholder="Repeat your password" />
                <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
            </div>
            <button type="submit" class="btn-nexus w-100" style="justify-content:center;padding:0.8rem;font-size:0.95rem;">
                <i class="fas fa-user-plus me-2"></i>Create Account
            </button>
        </form>

        <p class="text-center mt-4" style="font-size:0.85rem;color:var(--text-muted);">
            Already have an account?
            <a asp-action="Login" asp-route-returnUrl="@Model.ReturnUrl" style="color:var(--primary-light);font-weight:600;">Login</a>
        </p>

        <!-- Social Registration -->
        <div class="auth-divider">or sign up with</div>
        <form asp-action="ExternalLogin" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
            <button type="submit" name="provider" value="Google" class="btn-social btn-social-google">
                <svg width="18" height="18" viewBox="0 0 48 48">
                    <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                    <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                    <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                    <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                </svg>
                Sign up with Google
            </button>
            <button type="submit" name="provider" value="Facebook" class="btn-social btn-social-facebook">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#1877F2">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
                Sign up with Facebook
            </button>
        </form>
    </div>
</div>
