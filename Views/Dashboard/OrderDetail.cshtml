@model NexusGear.Models.Order
@{
    ViewData["Title"] = "Order " + Model.OrderNumber + " - NexusGear";
}

<div class="container py-5" style="max-width:900px;">
    <!-- Print-only invoice header -->
    <div class="print-only">
        <div class="print-invoice-header">
            <div>
                <div class="brand-print">NEXUSGEAR</div>
                <div style="font-size:0.8rem;color:#666;margin-top:2px;">Your Gaming Gear Destination</div>
            </div>
            <div style="text-align:right;">
                <div style="font-size:1rem;font-weight:700;color:#111;">INVOICE</div>
                <div style="font-size:0.8rem;color:#666;">Order #@Model.OrderNumber</div>
                <div style="font-size:0.8rem;color:#666;">Date: @Model.CreatedAt.ToString("MMMM d, yyyy")</div>
            </div>
        </div>
    </div>

    <nav aria-label="breadcrumb" class="mb-4 no-print">
        <ol class="breadcrumb"><li class="breadcrumb-item"><a href="/">Home</a></li><li class="breadcrumb-item"><a href="/Dashboard">Dashboard</a></li><li class="breadcrumb-item"><a href="/Dashboard/Orders">Orders</a></li><li class="breadcrumb-item active">@Model.OrderNumber</li></ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <h1 style="font-family:'Orbitron',sans-serif;font-size:1.2rem;font-weight:800;">Order <span style="color:var(--primary);">@Model.OrderNumber</span></h1>
        <span class="status-badge status-@Model.Status">@Model.Status</span>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-3"><div class="glass-card p-3 text-center"><p style="color:var(--text-muted);font-size:0.72rem;text-transform:uppercase;letter-spacing:1px;margin-bottom:0.3rem;">Placed On</p><p style="font-weight:600;color:var(--text-primary);margin:0;">@Model.CreatedAt.ToString("MMM d, yyyy")</p></div></div>
        <div class="col-md-3"><div class="glass-card p-3 text-center"><p style="color:var(--text-muted);font-size:0.72rem;text-transform:uppercase;letter-spacing:1px;margin-bottom:0.3rem;">Payment</p><p style="font-weight:600;color:var(--text-primary);margin:0;">@(Model.PaymentMethod == "card" ? "Card" : "Cash on Delivery")</p></div></div>
        <div class="col-md-3"><div class="glass-card p-3 text-center"><p style="color:var(--text-muted);font-size:0.72rem;text-transform:uppercase;letter-spacing:1px;margin-bottom:0.3rem;">Items</p><p style="font-weight:600;color:var(--text-primary);margin:0;">@Model.OrderItems.Count</p></div></div>
        <div class="col-md-3"><div class="glass-card p-3 text-center"><p style="color:var(--text-muted);font-size:0.72rem;text-transform:uppercase;letter-spacing:1px;margin-bottom:0.3rem;">Total</p><p style="font-family:'Orbitron',sans-serif;font-weight:700;color:var(--accent);margin:0;font-size:1rem;">$@Model.Total.ToString("0.00")</p></div></div>
    </div>

    <div class="glass-card p-4 mb-4">
        <p style="font-family:'Orbitron',sans-serif;font-size:0.82rem;font-weight:700;color:var(--primary-light);margin-bottom:1rem;border-bottom:1px solid var(--border);padding-bottom:0.5rem;">Order Items</p>
        @foreach (var item in Model.OrderItems)
        {
            string fallback = $"https://placehold.co/80x80/150020/a855f7?text=Product";
            <div class="d-flex align-items-center gap-3 py-3" style="border-bottom:1px solid rgba(168,85,247,0.07);">
                <img src="@(item.Product?.ImageUrl ?? fallback)" alt="@item.Product?.Name" style="width:70px;height:70px;object-fit:cover;border-radius:8px;background:var(--bg-surface);" onerror="this.src='@fallback'" />
                <div class="flex-1">
                    <a href="/shop/@item.Product?.Slug" class="text-decoration-none"><p style="font-weight:700;color:var(--text-primary);margin:0;">@(item.ProductName ?? item.Product?.Name)</p></a>
                    <p style="color:var(--text-muted);font-size:0.78rem;margin:0;">Qty: @item.Quantity × $@item.UnitPrice.ToString("0.00")</p>
                </div>
                <p style="font-family:'Orbitron',sans-serif;font-weight:700;color:var(--accent);margin:0;font-size:0.92rem;">$@item.Total.ToString("0.00")</p>
            </div>
        }
        <div class="mt-3 pt-2">
            <div class="d-flex justify-content-between text-muted mb-1" style="font-size:0.88rem;"><span>Subtotal</span><span>$@Model.Subtotal.ToString("0.00")</span></div>
            <div class="d-flex justify-content-between text-muted mb-1" style="font-size:0.88rem;"><span>Shipping</span><span style="@(Model.ShippingCost == 0 ? "color:var(--success);" : "")">@(Model.ShippingCost == 0 ? "FREE" : "$" + Model.ShippingCost.ToString("0.00"))</span></div>
            <div class="d-flex justify-content-between mt-2 pt-2" style="border-top:1px solid var(--border);"><strong style="color:var(--text-primary);">Total</strong><strong style="font-family:'Orbitron',sans-serif;color:var(--accent);font-size:1rem;">$@Model.Total.ToString("0.00")</strong></div>
        </div>
    </div>

    <div class="glass-card p-4 mb-4">
        <p style="font-family:'Orbitron',sans-serif;font-size:0.82rem;font-weight:700;color:var(--primary-light);margin-bottom:0.75rem;">Shipping Address</p>
        <p style="color:var(--text-secondary);margin:0;line-height:1.7;">@Model.ShippingAddress, @Model.ShippingCity, @Model.ShippingCountry @Model.ShippingPostalCode</p>
    </div>

    <div class="d-flex gap-3 flex-wrap">
        <a href="/Dashboard/Orders" class="btn-nexus-outline btn-nexus-sm no-print"><i class="fas fa-arrow-left me-1"></i>Back to Orders</a>
        <button onclick="window.print()" class="btn-nexus btn-nexus-sm no-print" style="background:linear-gradient(135deg,#7c22d4,#be185d);">
            <i class="fas fa-print me-2"></i>Print Invoice
        </button>
    </div>
</div>
