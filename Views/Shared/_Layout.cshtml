@using Microsoft.AspNetCore.Identity
@inject SignInManager<NexusGear.Models.ApplicationUser> SignInManager
@inject UserManager<NexusGear.Models.ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NexusGear</title>
    <meta name="description" content="NexusGear — Your destination for elite gaming peripherals, RGB lighting and accessories." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />
    <link rel="stylesheet" href="~/css/nexus.css" />
    <style>.has-dropdown:hover .fa-chevron-down{transform:rotate(180deg);}</style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @{
        bool isAdmin = User.IsInRole("Admin");
        var currentUser = SignInManager.IsSignedIn(User) ? await UserManager.GetUserAsync(User) : null;
    }

    <!-- Top Bar -->
    <div class="topbar d-none d-md-block">
        <div class="container d-flex justify-content-between align-items-center">
            <span><i class="fas fa-bolt me-1"></i> Free shipping on orders over $50 &nbsp;|&nbsp; <i class="fas fa-headset me-1"></i> 24/7 Support</span>
            <div class="d-flex align-items-center gap-3">
                @if (SignInManager.IsSignedIn(User))
                {
                    <span>Welcome, <strong>@(currentUser?.FirstName ?? User.Identity!.Name!.Split('@')[0])</strong></span>
                    @if (isAdmin)
                    {
                        <a href="/Admin/Dashboard" class="text-white"><i class="fas fa-cog me-1"></i>Admin Panel</a>
                    }
                    else
                    {
                        <a href="/Dashboard" class="text-white"><i class="fas fa-user me-1"></i>My Account</a>
                    }
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" style="background:none;border:none;color:rgba(255,255,255,0.85);cursor:pointer;font-size:0.78rem;padding:0;">Logout</button>
                    </form>
                }
                else
                {
                    <a href="/Account/Login" class="text-white"><i class="fas fa-sign-in-alt me-1"></i>Login</a>
                    <a href="/Account/Register" class="text-white"><i class="fas fa-user-plus me-1"></i>Register</a>
                }
            </div>
        </div>
    </div>

    <!-- Main Navigation -->
    <nav class="nexus-nav">
        <div class="container">
            <div class="d-flex align-items-center justify-content-between w-100 gap-3">
                <a href="/" class="brand-logo">NEXUS<span style="color:#ec4899;">GEAR</span></a>

                <ul class="navbar-nav flex-row gap-1 d-none d-lg-flex mb-0">
                    <li><a class="nav-link-nx @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")" href="/">Home</a></li>
                    <li><a class="nav-link-nx @(ViewContext.RouteData.Values["controller"]?.ToString() == "Shop" ? "active" : "")" href="/Shop">Shop</a></li>
                    <li class="has-dropdown">
                        <a class="nav-link-nx" href="/Shop" style="display:inline-flex;align-items:center;gap:5px;">
                            Categories <i class="fas fa-chevron-down" style="font-size:0.6rem;opacity:0.65;transition:transform 0.2s;"></i>
                        </a>
                        @await Component.InvokeAsync("NavCategories")
                    </li>
                    <li><a class="nav-link-nx" href="/Shop?onlyDiscounted=true">Deals</a></li>
                    <li><a class="nav-link-nx" href="/Shop?sortBy=newest">New Arrivals</a></li>
                </ul>

                <div class="d-flex align-items-center gap-2">
                    <form action="/Shop" method="get" class="d-none d-xl-flex mb-0">
                        <input type="text" name="q" class="nav-search-input" placeholder="Search gear..." />
                        <button type="submit" class="nav-search-btn"><i class="fas fa-search"></i></button>
                    </form>

                    @if (SignInManager.IsSignedIn(User) && !isAdmin)
                    {
                        <a href="/Dashboard/Wishlist" class="nav-icon-btn" title="Wishlist"><i class="far fa-heart fa-lg"></i></a>
                    }

                    <a href="/Cart" class="cart-icon-wrap nav-icon-btn" title="Cart">
                        <i class="fas fa-shopping-bag fa-lg"></i>
                        <span class="cart-badge" id="cartCount">0</span>
                    </a>

                    @if (SignInManager.IsSignedIn(User))
                    {
                        <a href="@(isAdmin ? "/Admin/Dashboard" : "/Dashboard")" class="nav-icon-btn d-lg-none"><i class="fas fa-user fa-lg"></i></a>
                    }
                    else
                    {
                        <a href="/Account/Login" class="nav-icon-btn d-lg-none"><i class="fas fa-sign-in-alt fa-lg"></i></a>
                    }

                    <button class="navbar-toggler d-lg-none" id="mobileMenuToggle" type="button" style="border:1px solid var(--border);background:transparent;padding:6px 10px;">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                </div>
            </div>

            <!-- Mobile Menu -->
            <div id="mobileMenu" style="display:none;padding:1rem 0;border-top:1px solid var(--border);margin-top:0.75rem;">
                <ul class="list-unstyled mb-2">
                    <li><a class="nav-link-nx d-block mb-1" href="/">Home</a></li>
                    <li><a class="nav-link-nx d-block mb-1" href="/Shop">Shop All</a></li>
                    <li><a class="nav-link-nx d-block mb-1" href="/Shop?onlyDiscounted=true">Deals</a></li>
                    <li><a class="nav-link-nx d-block mb-1" href="/Shop?sortBy=newest">New Arrivals</a></li>
                </ul>
                <form action="/Shop" method="get" class="d-flex">
                    <input type="text" name="q" class="nav-search-input" style="width:100%;border-radius:var(--radius) 0 0 var(--radius);" placeholder="Search..." />
                    <button type="submit" class="nav-search-btn"><i class="fas fa-search"></i></button>
                </form>
            </div>
        </div>
    </nav>

    @Html.AntiForgeryToken()

    <main>
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="nexus-footer">
        <div class="container">
            <div class="row g-4 mb-4">
                <div class="col-lg-4">
                    <p class="footer-brand mb-2">NEXUSGEAR</p>
                    <p style="color:var(--text-muted);font-size:0.85rem;max-width:280px;line-height:1.7;">Your one-stop destination for elite gaming peripherals, RGB lighting, and battle-ready accessories. Level up your setup.</p>
                    <div class="d-flex gap-2 mt-3">
                        <a href="#" class="social-icon"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="social-icon"><i class="fab fa-twitter"></i></a>
                        <a href="#" class="social-icon"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="social-icon"><i class="fab fa-youtube"></i></a>
                        <a href="#" class="social-icon"><i class="fab fa-discord"></i></a>
                    </div>
                </div>
                <div class="col-6 col-lg-2">
                    <p class="footer-heading">Shop</p>
                    <a href="/Shop" class="footer-link">All Products</a>
                    <a href="/Shop?onlyDiscounted=true" class="footer-link">Deals &amp; Discounts</a>
                    <a href="/Shop?sortBy=newest" class="footer-link">New Arrivals</a>
                </div>
                <div class="col-6 col-lg-2">
                    <p class="footer-heading">Account</p>
                    <a href="/Dashboard" class="footer-link">My Dashboard</a>
                    <a href="/Dashboard/Orders" class="footer-link">My Orders</a>
                    <a href="/Dashboard/Wishlist" class="footer-link">Wishlist</a>
                    <a href="/Cart" class="footer-link">Cart</a>
                </div>
                <div class="col-lg-4">
                    <p class="footer-heading">Stay in the Loop</p>
                    <p style="color:var(--text-muted);font-size:0.85rem;margin-bottom:0.75rem;">Get exclusive deals and gear drops straight to your inbox.</p>
                    <div class="input-group">
                        <input type="email" class="newsletter-input form-control" placeholder="Enter your email" />
                        <button class="btn-nexus" style="border-radius:0 var(--radius) var(--radius) 0;padding:0.55rem 1.1rem;font-size:0.8rem;">Subscribe</button>
                    </div>
                </div>
            </div>
            <hr style="border-color:var(--border);" />
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
                <p class="footer-copy mb-0">&copy; 2026 NexusGear. All rights reserved.</p>
                <div class="d-flex gap-3">
                    <a href="#" style="color:var(--text-muted);font-size:0.8rem;">Privacy Policy</a>
                    <a href="#" style="color:var(--text-muted);font-size:0.8rem;">Terms of Service</a>
                    <a href="#" style="color:var(--text-muted);font-size:0.8rem;">Contact Us</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/nexus.js"></script>
    <script>
        document.getElementById('mobileMenuToggle')?.addEventListener('click', function() {
            var m = document.getElementById('mobileMenu');
            if (m) m.style.display = (m.style.display === 'none' || !m.style.display) ? 'block' : 'none';
        });
    </script>
    <script>
        // Newsletter subscribe (footer)
        document.querySelector('.nexus-footer .btn-nexus')?.addEventListener('click', function () {
            const input = this.closest('.input-group')?.querySelector('input[type="email"]');
            if (!input || !input.value.trim()) {
                showToast('Please enter a valid email address.', 'warning'); return;
            }
            showToast('You\'re subscribed! Welcome to the NexusGear community.', 'success');
            input.value = '';
        });

        @if (TempData["Success"] != null) {
            <text>document.addEventListener('DOMContentLoaded',()=>showToast('@Html.Raw(Html.Encode(TempData["Success"]!.ToString()))', 'success'));</text>
        }
        @if (TempData["Error"] != null) {
            <text>document.addEventListener('DOMContentLoaded',()=>showToast('@Html.Raw(Html.Encode(TempData["Error"]!.ToString()))', 'error'));</text>
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
